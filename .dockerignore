.git/

# Documentation
*.md

# IDE settings
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Dockerfiles
Dockerfile*
.dockerignore
docker-compose*

# Misc (exclude from build context but keep in repo)
.github/
dev_plan*
